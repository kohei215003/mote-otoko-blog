---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'モテ男育成塾 – 非モテから下克上した桐島の記録', ogImage } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | モテ男育成塾</title>
  {ogImage && <meta property="og:image" content={ogImage} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0a0a0a;
      --bg-card:   #111111;
      --bg-hover:  #161616;
      --border:    #222222;
      --text:      #e8e0d8;
      --text-muted:#888880;
      --accent:    #c8102e;
      --accent-dim:#8b0b20;
      --gold:      #b8912a;
      --gold-light:#d4a83a;
      --serif:     'Noto Serif JP', serif;
      --sans:      'Noto Sans JP', sans-serif;
      --max-w:     720px;
      --max-w-wide:1100px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 18px;
      line-height: 1.9;
      -webkit-font-smoothing: antialiased;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    /* ── HEADER ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .site-header__inner {
      max-width: var(--max-w-wide);
      margin: 0 auto;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-logo {
      font-family: var(--serif);
      font-weight: 900;
      font-size: 1.05rem;
      letter-spacing: .06em;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .site-logo::before {
      content: '';
      display: block;
      width: 6px;
      height: 28px;
      background: var(--accent);
      border-radius: 2px;
    }
    .site-nav {
      display: flex;
      gap: 28px;
      font-size: .85rem;
      letter-spacing: .08em;
      color: var(--text-muted);
    }
    .site-nav a:hover { color: var(--text); }

    /* ── MAIN ── */
    main { min-height: 80vh; }

    /* ── FOOTER ── */
    .site-footer {
      border-top: 1px solid var(--border);
      padding: 48px 24px;
      text-align: center;
      font-size: .8rem;
      color: var(--text-muted);
      letter-spacing: .06em;
    }

    /* ── CTA BUTTON ── */
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #06c755;
      color: #fff;
      font-family: var(--sans);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: .05em;
      padding: 18px 36px;
      border-radius: 6px;
      transition: opacity .2s, transform .2s;
    }
    .cta-btn:hover { opacity: .88; transform: translateY(-2px); }

    /* ── ARTICLE CARD ── */
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      transition: background .2s, border-color .2s, transform .2s;
    }
    .card:hover {
      background: var(--bg-hover);
      border-color: #333;
      transform: translateY(-3px);
    }
    .card__img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
    .card__body { padding: 24px 28px 28px; }
    .card__tag {
      font-size: .72rem;
      letter-spacing: .12em;
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .card__title {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.5;
      color: var(--text);
      margin-bottom: 12px;
    }
    .card__excerpt {
      font-size: .88rem;
      color: var(--text-muted);
      line-height: 1.8;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card__meta {
      margin-top: 20px;
      font-size: .75rem;
      color: var(--text-muted);
      letter-spacing: .06em;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .card__meta::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--border);
    }

    /* ── PROSE (記事本文) ── */
    .prose {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 24px;
      font-family: var(--sans);
      font-size: 1.05rem;
      line-height: 2.05;
      color: var(--text);
    }

    .prose h1 {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 900;
      line-height: 1.35;
      letter-spacing: -.01em;
      margin-bottom: 32px;
      color: #fff;
    }
    .prose h2 {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 700;
      margin-top: 72px;
      margin-bottom: 24px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
      color: #fff;
    }
    .prose h3 {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 700;
      margin-top: 48px;
      margin-bottom: 16px;
      color: var(--text);
    }
    .prose p {
      margin-bottom: 28px;
    }
    .prose p + p { margin-top: -4px; }

    .prose strong {
      color: #fff;
      font-weight: 700;
    }

    .prose blockquote {
      margin: 40px 0;
      padding: 24px 32px;
      border-left: 4px solid var(--accent);
      background: #13080a;
      border-radius: 0 4px 4px 0;
      font-family: var(--serif);
      font-size: 1.15rem;
      color: #ddd;
    }

    .prose img {
      width: 100%;
      border-radius: 6px;
      margin: 40px 0;
    }
    .prose .img-wide {
      width: calc(100% + 48px);
      margin-left: -24px;
      margin-right: -24px;
      border-radius: 0;
      max-width: none;
    }
    .prose figure {
      margin: 40px 0;
    }
    .prose figcaption {
      text-align: center;
      font-size: .8rem;
      color: var(--text-muted);
      margin-top: 10px;
      letter-spacing: .06em;
    }

    /* ドラマチックなセパレーター */
    .prose hr {
      border: none;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--border), transparent);
      margin: 64px 0;
    }

    /* インパクト数字 */
    .stat-block {
      background: #0f0f0f;
      border: 1px solid var(--border);
      border-left: 4px solid var(--gold);
      border-radius: 4px;
      padding: 28px 32px;
      margin: 40px 0;
    }
    .stat-block .num {
      font-family: var(--serif);
      font-size: 2.8rem;
      font-weight: 900;
      color: var(--gold-light);
      line-height: 1;
    }
    .stat-block .label {
      font-size: .85rem;
      color: var(--text-muted);
      margin-top: 6px;
      letter-spacing: .06em;
    }

    /* 吹き出し風セリフ */
    .dialogue {
      background: #0d0d0d;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 20px 24px;
      margin: 24px 0;
      font-style: italic;
      color: #ccc;
      position: relative;
    }
    .dialogue::before {
      content: '「';
      font-family: var(--serif);
      font-size: 3rem;
      line-height: 1;
      color: var(--accent);
      opacity: .3;
      position: absolute;
      top: 8px;
      left: 12px;
    }

    /* ── HERO ── */
    .article-hero {
      position: relative;
      width: 100%;
      max-height: 520px;
      overflow: hidden;
    }
    .article-hero img {
      width: 100%;
      height: 520px;
      object-fit: cover;
      object-position: center top;
      filter: brightness(.55);
    }
    .article-hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 30%, rgba(10,10,10,.95) 100%);
    }
    .article-hero__text {
      position: absolute;
      bottom: 48px;
      left: 50%;
      transform: translateX(-50%);
      width: 100%;
      max-width: var(--max-w);
      padding: 0 24px;
    }
    .article-hero__chapter {
      font-size: .75rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 14px;
    }
    .article-hero__title {
      font-family: var(--serif);
      font-size: clamp(1.7rem, 5vw, 2.8rem);
      font-weight: 900;
      line-height: 1.35;
      color: #fff;
      text-shadow: 0 2px 20px rgba(0,0,0,.8);
    }

    /* ── INDEX HERO ── */
    .index-hero {
      padding: 80px 24px 60px;
      text-align: center;
      border-bottom: 1px solid var(--border);
      background: radial-gradient(ellipse at 50% 0%, #1a0305 0%, var(--bg) 70%);
    }
    .index-hero__eyebrow {
      font-size: .78rem;
      letter-spacing: .25em;
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .index-hero__title {
      font-family: var(--serif);
      font-size: clamp(2rem, 6vw, 3.6rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.25;
      margin-bottom: 20px;
    }
    .index-hero__sub {
      font-size: 1rem;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.8;
    }

    /* ── ARTICLE LIST ── */
    .articles-section {
      max-width: var(--max-w-wide);
      margin: 0 auto;
      padding: 64px 24px;
    }
    .articles-section__label {
      font-size: .72rem;
      letter-spacing: .2em;
      color: var(--text-muted);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 32px;
    }
    .article-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 24px;
    }

    /* featured */
    .article-grid .card:first-child {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .article-grid .card:first-child .card__img {
      aspect-ratio: auto;
      height: 100%;
    }
    @media (max-width: 680px) {
      .article-grid .card:first-child {
        grid-template-columns: 1fr;
      }
    }

    /* ── CTA SECTION (記事末尾) ── */
    .cta-section {
      background: #0d0005;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 64px 24px;
      text-align: center;
      margin-top: 80px;
    }
    .cta-section__eyebrow {
      font-size: .75rem;
      letter-spacing: .2em;
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .cta-section__title {
      font-family: var(--serif);
      font-size: clamp(1.4rem, 4vw, 2rem);
      font-weight: 700;
      color: #fff;
      margin-bottom: 16px;
    }
    .cta-section__sub {
      color: var(--text-muted);
      font-size: .9rem;
      margin-bottom: 32px;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.8;
    }

    /* ── 記事ページ meta ── */
    .article-meta {
      max-width: var(--max-w);
      margin: 0 auto 48px;
      padding: 32px 24px 0;
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: .8rem;
      color: var(--text-muted);
      letter-spacing: .06em;
    }
    .article-meta__chapter {
      background: var(--accent);
      color: #fff;
      padding: 3px 10px;
      border-radius: 3px;
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .1em;
    }

    /* ── About / Contact ── */
    .page-content {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 80px 24px;
    }
    .page-title {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 900;
      color: #fff;
      margin-bottom: 48px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    /* ── LP HERO ── */
    .lp-hero {
      position: relative;
      height: 100svh;
      min-height: 600px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .lp-hero__bg {
      position: absolute;
      inset: 0;
    }
    .lp-hero__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      filter: brightness(.4);
    }
    .lp-hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10,10,10,.3) 0%, rgba(10,10,10,.7) 100%);
    }
    .lp-hero__content {
      position: relative;
      text-align: center;
      padding: 0 24px;
      max-width: 700px;
      width: 100%;
    }
    .lp-eyebrow {
      font-size: .75rem;
      letter-spacing: .28em;
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .lp-hero__title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 6vw, 3.4rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.3;
      margin-bottom: 20px;
      text-shadow: 0 2px 24px rgba(0,0,0,.8);
    }
    .lp-hero__sub {
      font-size: clamp(.9rem, 2.5vw, 1.1rem);
      color: rgba(255,255,255,.75);
      line-height: 1.9;
      margin-bottom: 40px;
    }
    .lp-scroll-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #fff;
      border: 1px solid rgba(255,255,255,.4);
      padding: 14px 28px;
      border-radius: 100px;
      font-size: .88rem;
      letter-spacing: .1em;
      transition: background .2s, border-color .2s;
    }
    .lp-scroll-btn:hover {
      background: rgba(255,255,255,.1);
      border-color: rgba(255,255,255,.7);
    }

    /* ── CHAPTER NAV ── */
    .chapter-nav {
      position: sticky;
      top: 64px;
      z-index: 90;
      background: rgba(10,10,10,.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: center;
      gap: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .chapter-nav a {
      padding: 14px 16px;
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--text-muted);
      white-space: nowrap;
      transition: color .2s;
      border-bottom: 2px solid transparent;
    }
    .chapter-nav a:hover {
      color: var(--text);
      border-bottom-color: var(--accent);
    }

    /* ── CHAPTER SECTION ── */
    .chapter {
      padding: 80px 0;
      border-bottom: 1px solid var(--border);
    }
    .chapter--alt {
      background: #0d0d0d;
    }
    .chapter-header {
      max-width: 720px;
      margin: 0 auto 56px;
      padding: 0 24px;
      text-align: center;
    }
    .chapter-label {
      display: inline-block;
      font-size: .72rem;
      letter-spacing: .25em;
      color: var(--accent);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 16px;
      padding: 4px 14px;
      border: 1px solid var(--accent-dim);
      border-radius: 100px;
    }
    .chapter-title {
      font-family: var(--serif);
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.4;
    }
    .prose h3 {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 700;
      margin-top: 48px;
      margin-bottom: 16px;
      color: #fff;
      padding-left: 14px;
      border-left: 3px solid var(--accent);
    }

    /* ── 特典セクション ── */
    .tokuten-section {
      background: #06000d;
      padding: 80px 24px 100px;
      position: relative;
      overflow: hidden;
    }
    .tokuten-section::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(184,145,42,.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .tokuten-inner {
      max-width: 760px;
      margin: 0 auto;
      text-align: center;
      position: relative;
    }
    .tokuten-eyebrow {
      font-size: .75rem;
      letter-spacing: .2em;
      color: var(--gold);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .tokuten-title {
      font-family: var(--serif);
      font-size: clamp(1.6rem, 5vw, 2.6rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.35;
      margin-bottom: 16px;
    }
    .tokuten-sub {
      color: var(--text-muted);
      font-size: .95rem;
      line-height: 1.9;
      margin-bottom: 48px;
    }
    .tokuten-block {
      background: #0d0a00;
      border: 1px solid #2a2000;
      border-radius: 8px;
      padding: 28px 20px;
      text-align: left;
      margin-bottom: 20px;
    }
    .tokuten-block--featured {
      background: #0a0800;
      border: 1px solid var(--gold);
      box-shadow: 0 0 40px rgba(184,145,42,.15);
      padding: 32px 24px;
      margin-bottom: 32px;
    }
    .tokuten-block__header {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .tokuten-block__num {
      flex-shrink: 0;
      font-size: .7rem;
      letter-spacing: .12em;
      color: var(--text-muted);
      font-weight: 700;
      background: #1a1a1a;
      padding: 4px 12px;
      border-radius: 100px;
    }
    .tokuten-block__num--gold {
      color: var(--gold);
      background: rgba(184,145,42,.12);
    }
    .tokuten-block__title {
      font-family: var(--serif);
      font-size: clamp(1.1rem, 3vw, 1.5rem);
      font-weight: 700;
      color: #fff;
      line-height: 1.5;
    }
    .tokuten-block__body {
      font-size: .9rem;
      color: var(--text-muted);
      line-height: 1.9;
    }
    .tokuten-list {
      list-style: none;
      margin: 24px 0 20px;
    }
    .tokuten-list li {
      padding: 12px 0 12px 24px;
      border-bottom: 1px solid #1a1400;
      font-size: .92rem;
      color: var(--text-muted);
      line-height: 1.8;
      position: relative;
    }
    .tokuten-list li::before {
      content: '▶';
      position: absolute;
      left: 0;
      color: var(--gold);
      font-size: .7rem;
      top: 15px;
    }
    .tokuten-list li strong { color: var(--gold-light); font-weight: 700; }
    .tokuten-emphasis {
      background: rgba(200,16,46,.08);
      border: 1px solid rgba(200,16,46,.25);
      border-radius: 6px;
      padding: 16px 20px;
      font-size: .92rem;
      color: #ccc;
      line-height: 1.8;
      text-align: center;
    }
    .tokuten-emphasis strong { color: #fff; font-weight: 700; }
    .tokuten-cta { text-align: center; }
    .tokuten-cta__method {
      margin-bottom: 24px;
      color: var(--text-muted);
      font-size: .88rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .tokuten-cta__step {
      background: var(--gold);
      color: #000;
      font-size: .72rem;
      font-weight: 700;
      padding: 4px 12px;
      border-radius: 4px;
      letter-spacing: .06em;
      flex-shrink: 0;
    }
    .cta-btn--xl {
      font-size: 1.05rem;
      padding: 20px 32px;
      border-radius: 8px;
      box-shadow: 0 8px 32px rgba(6,199,85,.3);
      width: 100%;
      max-width: 420px;
      justify-content: center;
    }
    .tokuten-cta__arrow {
      margin-top: 14px;
      font-size: .85rem;
      color: var(--gold);
      letter-spacing: .08em;
      font-weight: 700;
    }
    .tokuten-cta__small {
      margin-top: 12px;
      font-size: .75rem;
      color: var(--text-muted);
    }
    .tokuten-video-imgs {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin: 20px 0 28px;
    }
    .tokuten-video-img {
      width: 100%;
      border-radius: 6px;
      border: 1px solid #2a2000;
      aspect-ratio: 16/10;
      object-fit: cover;
    }
    .tokuten-video-badge {
